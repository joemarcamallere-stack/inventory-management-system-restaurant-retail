// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BusinessModule {
  RETAIL
  RESTAURANT
}

enum UserRole {
  Admin
  Manager
  Staff
  Cashier
  KitchenStaff
  RetailStaff
}

enum UserStatus {
  Active
  Inactive
}

enum NotificationType {
  LOW_STOCK
  EXPIRY_WARNING
  EXPIRY_REACHED
  BUNDLE_APPROVED
  BUNDLE_REJECTED
  KITCHEN_ORDER_READY
}

enum InventoryItemType {
  RETAIL_ITEM
  INGREDIENT
  MENU_ITEM
  SUPPLY
  BUNDLE
}

model Business {
  id                 String              @id @default(uuid())
  name               String              @unique
  modules            BusinessModule[]    @default([RETAIL])
  users              User[]
  locations          Location[]
  items              InventoryItem[]
  stockMovements     StockMovement[]
  recipes            Recipe[]
  kitchenOrders      KitchenOrder[]
  suppliers          Supplier[]
  purchaseOrders     PurchaseOrder[]
  goodsReceipts      GoodsReceipt[]
  transfers          Transfer[]
  sales              Sale[]
  bundles            BundlePackage[]
  stockAdjustments   StockAdjustment[]
  diningTables       DiningTable[]
  notifications      Notification[]
  categories         Category[]
  restaurantSettings RestaurantSetting[]
  businessSettings   BusinessSetting[]
  posSettings        POSSetting[]
  posOrders          POSOrder[]
  payments           Payment[]
  receipts           Receipt[]
  ingredientAlternatives IngredientAlternative[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model BusinessSetting {
  id         String   @id @default(uuid())
  key        String
  value      Json
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, key])
  @@index([businessId])
}

model POSSetting {
  id         String         @id @default(uuid())
  key        String
  value      Json
  module     BusinessModule
  businessId String
  business   Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([businessId, module, key])
  @@index([businessId])
  @@index([businessId, module])
}

model RestaurantSetting {
  id         String   @id @default(uuid())
  key        String
  value      Json
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, key])
  @@index([businessId])
}

model User {
  id                     String            @id @default(uuid())
  name                   String
  email                  String            @unique
  passwordHash           String
  role                   UserRole          @default(Staff)
  status                 UserStatus        @default(Active)
  businessId             String
  business               Business          @relation(fields: [businessId], references: [id])
  stockMovements         StockMovement[]
  kitchenOrders          KitchenOrder[]
  purchaseOrders         PurchaseOrder[]   @relation("POCreatedBy")
  receivedPurchaseOrders PurchaseOrder[]   @relation("POReceivedBy")
  goodsReceipts          GoodsReceipt[]
  transfers              Transfer[]
  sales                  Sale[]
  posOrders              POSOrder[]
  payments               Payment[]
  createdBundles         BundlePackage[]   @relation("BundleCreatedBy")
  approvedBundles        BundlePackage[]   @relation("BundleApprovedBy")
  createdAdjustments     StockAdjustment[] @relation("AdjustmentCreatedBy")
  reviewedAdjustments    StockAdjustment[] @relation("AdjustmentReviewedBy")
  notifications          Notification[]
  lastLogin              DateTime          @default(now())
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
}

model Location {
  id              String                @id @default(uuid())
  name            String
  address         String
  manager         String
  phone           String
  itemCount       Int                   @default(0)
  businessId      String
  business        Business              @relation(fields: [businessId], references: [id])
  items           InventoryItem[]
  stockMovements  StockMovement[]
  transfersFrom   Transfer[]            @relation("TransferFrom")
  transfersTo     Transfer[]            @relation("TransferTo")
  sales           Sale[]
  posOrders       POSOrder[]
  bundles         BundlePackage[]
  adjustmentItems StockAdjustmentItem[]
  kitchenOrders   KitchenOrder[]
  diningTables    DiningTable[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([businessId, name])
}

model Category {
  id          String          @id @default(uuid())
  name        String
  description String?
  module      BusinessModule
  businessId  String
  business    Business        @relation(fields: [businessId], references: [id])
  items       InventoryItem[]
  suppliers   Supplier[]      @relation("SupplierCategory")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([businessId, name, module])
  @@index([businessId, module])
}

model DiningTable {
  id            String            @id @default(uuid())
  tableNumber   String
  capacity      Int
  status        DiningTableStatus @default(AVAILABLE)
  floor         String?
  notes         String?
  locationId    String
  location      Location          @relation(fields: [locationId], references: [id])
  businessId    String
  business      Business          @relation(fields: [businessId], references: [id])
  kitchenOrders KitchenOrder[]
  posOrders     POSOrder[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([businessId, locationId, tableNumber])
  @@index([businessId, status])
  @@index([locationId])
}

model Notification {
  id         String           @id @default(uuid())
  type       NotificationType
  title      String
  message    String
  isRead     Boolean          @default(false)
  readAt     DateTime?
  entityType String?
  entityId   String?
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String
  business   Business         @relation(fields: [businessId], references: [id])
  createdAt  DateTime         @default(now())

  @@index([userId, isRead])
  @@index([businessId, createdAt])
  @@index([userId, createdAt])
}

model InventoryItem {
  id                 String                @id @default(uuid())
  name               String
  itemType           InventoryItemType     @default(RETAIL_ITEM)
  sku                String?
  barcode            String?
  category           String
  categoryId         String?
  categoryRef        Category?             @relation(fields: [categoryId], references: [id])
  targetCustomer     String? // Male, Female, Unisex
  subcategory        String?
  size               String?
  condition          String? // Excellent, Good, Fair, Damaged
  quantity           Float                 @default(0.0)
  price              Float                 @default(0.0)
  costPrice          Float?
  imageUrl           String?
  unit               String?
  minStock           Float?
  maxStock           Float?
  reorderPoint       Float?
  expiryDate         DateTime?
  storageTemperature String?
  dateAdded          DateTime              @default(now())
  locationId         String
  location           Location              @relation(fields: [locationId], references: [id])
  businessId         String
  business           Business              @relation(fields: [businessId], references: [id])
  stockMovements     StockMovement[]
  recipeIngredients  RecipeIngredient[]
  menuRecipes        Recipe[]              @relation("RecipeMenuItem")
  ingredientAlternativeParents IngredientAlternative[] @relation("IngredientAlternativeParent")
  ingredientAlternativeReplacements IngredientAlternative[] @relation("IngredientAlternativeReplacement")
  purchaseOrderItems PurchaseOrderItem[]
  goodsReceiptItems  GoodsReceiptItem[]
  transferItems      TransferItem[]
  saleItems          SaleItem[]
  posOrderItems      POSOrderItem[]
  bundleItems        BundleItem[]
  adjustmentItems    StockAdjustmentItem[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@unique([businessId, sku])
  @@unique([businessId, barcode])
  @@index([businessId])
  @@index([businessId, itemType])
  @@index([businessId, locationId])
}

model Recipe {
  id              String             @id @default(uuid())
  name            String
  category        String
  servings        Float
  yieldPercentage Float              @default(100.0)
  prepTimeMinutes Int?
  instructions    String?
  targetFoodCost  Float?
  sellingPrice    Float?
  isActive        Boolean            @default(true)
  imageUrl        String?
  isVegetarian    Boolean            @default(false)
  isVegan         Boolean            @default(false)
  isGlutenFree    Boolean            @default(false)
  isDairyFree     Boolean            @default(false)
  isNutFree       Boolean            @default(false)
  isHalal         Boolean            @default(false)
  allergenNotes   String?
  modifiers       Json               @default("[]")
  menuItemId      String?
  menuItem        InventoryItem?     @relation("RecipeMenuItem", fields: [menuItemId], references: [id])
  ingredients     RecipeIngredient[]
  kitchenOrders   KitchenOrder[]
  posOrderItems   POSOrderItem[]
  businessId      String
  business        Business           @relation(fields: [businessId], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([businessId, name])
  @@index([businessId, isActive])
}

model RecipeIngredient {
  id        String        @id @default(uuid())
  recipeId  String
  recipe    Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id])
  quantity  Float
  unit      String?
  unitCost  Float?
  totalCost Float?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([recipeId, itemId])
  @@index([itemId])
}

model IngredientAlternative {
  id                      String        @id @default(uuid())
  parentIngredientId      String
  parentIngredient        InventoryItem @relation("IngredientAlternativeParent", fields: [parentIngredientId], references: [id], onDelete: Cascade)
  alternativeIngredientId String
  alternativeIngredient   InventoryItem @relation("IngredientAlternativeReplacement", fields: [alternativeIngredientId], references: [id], onDelete: Cascade)
  additionalPrice         Float         @default(0)
  isAvailable             Boolean       @default(true)
  businessId              String
  business                Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@unique([businessId, parentIngredientId, alternativeIngredientId])
  @@index([businessId])
  @@index([parentIngredientId])
  @@index([alternativeIngredientId])
}

enum DiningTableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum KitchenOrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  VOIDED
}

model KitchenOrder {
  id            String             @id @default(uuid())
  receiptNo     String
  quantity      Float
  status        KitchenOrderStatus @default(COMPLETED)
  notes         String?
  voidReason    String?
  voidedAt      DateTime?
  recipeId      String
  recipe        Recipe             @relation(fields: [recipeId], references: [id])
  locationId    String?
  location      Location?          @relation(fields: [locationId], references: [id])
  tableId       String?
  table         DiningTable?       @relation(fields: [tableId], references: [id])
  saleId        String?            @unique
  sale          Sale?              @relation(fields: [saleId], references: [id])
  posOrderId    String?
  posOrder      POSOrder?          @relation(fields: [posOrderId], references: [id], onDelete: SetNull)
  businessId    String
  business      Business           @relation(fields: [businessId], references: [id])
  completedById String?
  completedBy   User?              @relation(fields: [completedById], references: [id])
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([businessId, receiptNo])
  @@index([businessId, createdAt])
  @@index([businessId, recipeId])
  @@index([businessId, status])
  @@index([posOrderId])
}

enum StockMovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  SALE
  RECIPE_CONSUMPTION
  SPOILAGE
  EXPIRY
  VOID_RESTOCK
}

model StockMovement {
  id               String            @id @default(uuid())
  type             StockMovementType
  quantity         Float
  previousQuantity Float
  newQuantity      Float
  unit             String?
  reason           String?
  referenceType    String?
  referenceId      String?
  notes            String?
  itemId           String
  item             InventoryItem     @relation(fields: [itemId], references: [id])
  locationId       String
  location         Location          @relation(fields: [locationId], references: [id])
  businessId       String
  business         Business          @relation(fields: [businessId], references: [id])
  module           BusinessModule    @default(RETAIL)
  createdById      String?
  createdBy        User?             @relation(fields: [createdById], references: [id])
  createdAt        DateTime          @default(now())

  @@index([businessId, createdAt])
  @@index([businessId, itemId])
  @@index([businessId, locationId])
  @@index([businessId, type])
  @@index([businessId, module, createdAt])
}

// ─── Supplier ────────────────────────────────────────────────────────────────

model Supplier {
  id             String          @id @default(uuid())
  name           String
  contactPerson  String?
  email          String?
  phone          String?
  address        String?
  category       String?
  categoryId     String?
  categoryRef    Category?       @relation("SupplierCategory", fields: [categoryId], references: [id])
  isActive       Boolean         @default(true)
  businessId     String
  business       Business        @relation(fields: [businessId], references: [id])
  module         BusinessModule  @default(RETAIL)
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([businessId, name, module])
  @@index([businessId])
  @@index([businessId, module])
}

// ─── Purchase Orders ─────────────────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  REJECTED
  CANCELLED
}

model PurchaseOrder {
  id               String              @id @default(uuid())
  orderNumber      String
  supplierId       String?
  supplier         Supplier?           @relation(fields: [supplierId], references: [id])
  status           PurchaseOrderStatus @default(DRAFT)
  notes            String?
  paymentMethod    String?
  paymentTerms     String?
  expectedDelivery DateTime?
  rejectionReason  String?
  rejectedAt       DateTime?
  totalAmount      Float               @default(0)
  businessId       String
  business         Business            @relation(fields: [businessId], references: [id])
  module           BusinessModule      @default(RETAIL)
  createdById      String?
  createdBy        User?               @relation("POCreatedBy", fields: [createdById], references: [id])
  receivedById     String?
  receivedBy       User?               @relation("POReceivedBy", fields: [receivedById], references: [id])
  receivedAt       DateTime?
  items            PurchaseOrderItem[]
  goodsReceipts    GoodsReceipt[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([businessId, orderNumber])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([businessId, module, status])
}

model PurchaseOrderItem {
  id              String             @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem?     @relation(fields: [inventoryItemId], references: [id])
  name            String
  quantity        Float
  receivedQty     Float              @default(0)
  rejectedQty     Float              @default(0)
  unitPrice       Float
  totalPrice      Float
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  receiptItems    GoodsReceiptItem[]

  @@index([purchaseOrderId])
}

model GoodsReceipt {
  id              String             @id @default(uuid())
  receiptNumber   String
  purchaseOrderId String
  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  receivedById    String?
  receivedBy      User?              @relation(fields: [receivedById], references: [id])
  notes           String?
  businessId      String
  business        Business           @relation(fields: [businessId], references: [id])
  module          BusinessModule     @default(RETAIL)
  items           GoodsReceiptItem[]
  createdAt       DateTime           @default(now())

  @@unique([businessId, receiptNumber])
  @@index([businessId, createdAt])
  @@index([purchaseOrderId])
  @@index([businessId, module, createdAt])
}

model GoodsReceiptItem {
  id                  String            @id @default(uuid())
  goodsReceiptId      String
  goodsReceipt        GoodsReceipt      @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  purchaseOrderItemId String
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])
  inventoryItemId     String?
  inventoryItem       InventoryItem?    @relation(fields: [inventoryItemId], references: [id])
  receivedQty         Float
  rejectedQty         Float             @default(0)
  condition           String?
  notes               String?
  createdAt           DateTime          @default(now())

  @@index([goodsReceiptId])
  @@index([purchaseOrderItemId])
  @@index([inventoryItemId])
}

// ─── Transfers ───────────────────────────────────────────────────────────────

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model Transfer {
  id             String         @id @default(uuid())
  transferNumber String
  fromLocationId String
  fromLocation   Location       @relation("TransferFrom", fields: [fromLocationId], references: [id])
  toLocationId   String
  toLocation     Location       @relation("TransferTo", fields: [toLocationId], references: [id])
  status         TransferStatus @default(PENDING)
  notes          String?
  businessId     String
  business       Business       @relation(fields: [businessId], references: [id])
  module         BusinessModule @default(RETAIL)
  createdById    String?
  createdBy      User?          @relation(fields: [createdById], references: [id])
  completedAt    DateTime?
  items          TransferItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([businessId, transferNumber])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([businessId, module, status])
}

model TransferItem {
  id              String        @id @default(uuid())
  transferId      String
  transfer        Transfer      @relation(fields: [transferId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Float
  createdAt       DateTime      @default(now())

  @@index([transferId])
}

// ─── Sales ───────────────────────────────────────────────────────────────────

enum SaleStatus {
  COMPLETED
  REFUNDED
  PARTIAL_REFUND
}

model Sale {
  id                String         @id @default(uuid())
  transactionNumber String
  locationId        String
  location          Location       @relation(fields: [locationId], references: [id])
  cashierId         String?
  cashier           User?          @relation(fields: [cashierId], references: [id])
  subtotal          Float
  discount          Float          @default(0)
  tax               Float          @default(0)
  total             Float
  paymentMethod     String
  amountPaid        Float
  change            Float          @default(0)
  customer          String?
  status            SaleStatus     @default(COMPLETED)
  refundReason      String?
  refundedAt        DateTime?
  kitchenOrder      KitchenOrder?
  posOrder          POSOrder?
  payments          Payment[]
  receipts          Receipt[]
  businessId        String
  business          Business       @relation(fields: [businessId], references: [id])
  module            BusinessModule @default(RETAIL)
  items             SaleItem[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([businessId, transactionNumber])
  @@index([businessId, createdAt])
  @@index([businessId, refundedAt])
  @@index([businessId, locationId])
  @@index([businessId, status])
  @@index([businessId, module, createdAt])
}

model SaleItem {
  id              String        @id @default(uuid())
  saleId          String
  sale            Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  name            String
  quantity        Float
  unitPrice       Float
  totalPrice      Float
  createdAt       DateTime      @default(now())

  @@index([saleId])
}

// ─── Stock Adjustments ───────────────────────────────────────────────────────

enum POSOrderType {
  DINE_IN
  TAKEOUT
  MIXED
  RETAIL
}

enum POSOrderStatus {
  PENDING
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
  VOIDED
}

enum POSPaymentStatus {
  NOT_PAID
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
  VOIDED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
  VOIDED
}

model POSOrder {
  id            String           @id @default(uuid())
  orderNumber   String
  orderType     POSOrderType     @default(RETAIL)
  status        POSOrderStatus   @default(PENDING)
  paymentStatus POSPaymentStatus @default(NOT_PAID)
  customerName  String?
  contactNumber String?
  tableName     String?
  partySize     Int?
  subtotal      Float            @default(0)
  discount      Float            @default(0)
  discountType  String?
  tax           Float            @default(0)
  serviceCharge Float            @default(0)
  total         Float            @default(0)
  notes         String?
  voidReason    String?
  voidedAt      DateTime?
  completedAt   DateTime?
  locationId    String
  location      Location         @relation(fields: [locationId], references: [id])
  tableId       String?
  table         DiningTable?     @relation(fields: [tableId], references: [id])
  saleId        String?          @unique
  sale          Sale?            @relation(fields: [saleId], references: [id])
  businessId    String
  business      Business         @relation(fields: [businessId], references: [id])
  module        BusinessModule   @default(RETAIL)
  createdById   String?
  createdBy     User?            @relation(fields: [createdById], references: [id])
  items         POSOrderItem[]
  kitchenOrders KitchenOrder[]
  payments      Payment[]
  receipts      Receipt[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([businessId, orderNumber])
  @@index([businessId, module, status])
  @@index([businessId, paymentStatus])
  @@index([businessId, createdAt])
  @@index([businessId, locationId])
  @@index([tableId])
  @@index([saleId])
}

model POSOrderItem {
  id              String         @id @default(uuid())
  posOrderId      String
  posOrder        POSOrder       @relation(fields: [posOrderId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  recipeId        String?
  recipe          Recipe?        @relation(fields: [recipeId], references: [id])
  name            String
  category        String?
  quantity        Float          @default(1)
  unitPrice       Float          @default(0)
  totalPrice      Float          @default(0)
  itemType        String?
  notes           String?
  customizations  Json           @default("[]")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([posOrderId])
  @@index([inventoryItemId])
  @@index([recipeId])
}

model Payment {
  id            String        @id @default(uuid())
  paymentNumber String
  method        String
  amountDue     Float
  amountPaid    Float
  change        Float         @default(0)
  status        PaymentStatus @default(PAID)
  saleId        String?
  sale          Sale?         @relation(fields: [saleId], references: [id])
  posOrderId    String?
  posOrder      POSOrder?     @relation(fields: [posOrderId], references: [id])
  businessId    String
  business      Business      @relation(fields: [businessId], references: [id])
  processedById String?
  processedBy   User?         @relation(fields: [processedById], references: [id])
  paidAt        DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  receipts      Receipt[]

  @@unique([businessId, paymentNumber])
  @@index([businessId, paidAt])
  @@index([businessId, method])
  @@index([saleId])
  @@index([posOrderId])
}

model Receipt {
  id            String    @id @default(uuid())
  receiptNumber String
  receiptData   Json
  printedAt     DateTime?
  saleId        String?
  sale          Sale?     @relation(fields: [saleId], references: [id])
  posOrderId    String?
  posOrder      POSOrder? @relation(fields: [posOrderId], references: [id])
  paymentId     String?
  payment       Payment?  @relation(fields: [paymentId], references: [id])
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([businessId, receiptNumber])
  @@index([businessId, createdAt])
  @@index([saleId])
  @@index([posOrderId])
  @@index([paymentId])
}

enum AdjustmentType {
  ADD
  REMOVE
  DAMAGE
  LOST
  FOUND
  RECOUNT
}

enum AdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
}

model StockAdjustment {
  id               String                @id @default(uuid())
  adjustmentNumber String
  type             AdjustmentType
  reason           String
  status           AdjustmentStatus      @default(PENDING)
  rejectionReason  String?
  businessId       String
  business         Business              @relation(fields: [businessId], references: [id])
  module           BusinessModule        @default(RETAIL)
  createdById      String?
  createdBy        User?                 @relation("AdjustmentCreatedBy", fields: [createdById], references: [id])
  reviewedById     String?
  reviewedBy       User?                 @relation("AdjustmentReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt       DateTime?
  items            StockAdjustmentItem[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@unique([businessId, adjustmentNumber])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([businessId, module, status])
}

model StockAdjustmentItem {
  id              String          @id @default(uuid())
  adjustmentId    String
  adjustment      StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem   @relation(fields: [inventoryItemId], references: [id])
  quantityChange  Float
  locationId      String
  location        Location        @relation(fields: [locationId], references: [id])
  createdAt       DateTime        @default(now())

  @@index([adjustmentId])
  @@index([inventoryItemId])
}

// ─── Bundles ─────────────────────────────────────────────────────────────────

enum BundleStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  INACTIVE
}

model BundlePackage {
  id              String       @id @default(uuid())
  name            String
  description     String?
  imageUrl        String?
  discount        Float        @default(0)
  price           Float        @default(0)
  status          BundleStatus @default(PENDING)
  rejectionReason String?
  locationId      String?
  location        Location?    @relation(fields: [locationId], references: [id])
  businessId      String
  business        Business     @relation(fields: [businessId], references: [id])
  createdById     String?
  createdBy       User?        @relation("BundleCreatedBy", fields: [createdById], references: [id])
  approvedById    String?
  approvedBy      User?        @relation("BundleApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  items           BundleItem[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([businessId])
  @@index([businessId, status])
}

model BundleItem {
  id              String        @id @default(uuid())
  bundleId        String
  bundle          BundlePackage @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Float
  createdAt       DateTime      @default(now())

  @@index([bundleId])
}
